<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://www.flowable.org/processdef">
 
    <!-- 内部报警信号定义 -->
    <signal id="internalAlarmSignal" name="internalAlarmSignal" flowable:scope="processInstance"/>
 
    <!-- 广告 AI 助理流程：并行双环架构 -->
    <process id="adAgentProcess" name="广告 AI 助理流程" isExecutable="true">
        
        <startEvent id="startEvent" name="激活 Skill"/>
        
        <sequenceFlow id="flow_start_to_fork" sourceRef="startEvent" targetRef="parallelFork"/>
        
        <!-- 并行拆分：监控支线与策略支线同步运行 -->
        <parallelGateway id="parallelFork" name="拆分监控与策略"/>
 
        <!-- ================================================================= -->
        <!-- 监控支线 (Branch 1) -->
        <!-- ================================================================= -->
        <sequenceFlow id="flow_fork_to_monitor" sourceRef="parallelFork" targetRef="monitorTask"/>
        
        <serviceTask id="monitorTask" name="监控数据" flowable:expression="${adMonitorService.monitor(execution)}"/>
        
        <sequenceFlow id="flow_monitor_to_alarm_gw" sourceRef="monitorTask" targetRef="monitorAlarmGateway"/>
        
        <exclusiveGateway id="monitorAlarmGateway" name="异常报警？" default="flow_no_alarm"/>
        
        <!-- 路径：有异常，抛出内部信号 -->
        <sequenceFlow id="flow_alarm_triggered" name="是" sourceRef="monitorAlarmGateway" targetRef="throwAlarmSignal">
            <conditionExpression xsi:type="tFormalExpression">${alarmTriggered == true}</conditionExpression>
        </sequenceFlow>
        
        <intermediateThrowEvent id="throwAlarmSignal" name="通知策略模块">
            <signalEventDefinition signalRef="internalAlarmSignal"/>
        </intermediateThrowEvent>
        
        <sequenceFlow id="flow_after_alarm" sourceRef="throwAlarmSignal" targetRef="monitorWaitTimer"/>
 
        <!-- 路径：无异常，直接进入等待 -->
        <sequenceFlow id="flow_no_alarm" name="否" sourceRef="monitorAlarmGateway" targetRef="monitorWaitTimer"/>
 
        <intermediateCatchEvent id="monitorWaitTimer" name="等待下轮监控">
            <timerEventDefinition>
                <timeDuration>${monitorInterval}</timeDuration>
            </timerEventDefinition>
        </intermediateCatchEvent>
 
        <sequenceFlow id="flow_loop_monitor" sourceRef="monitorWaitTimer" targetRef="monitorTask"/>
 
        <!-- ================================================================= -->
        <!-- 策略支线 (Branch 2) -->
        <!-- ================================================================= -->
        <sequenceFlow id="flow_fork_to_strat_gw" sourceRef="parallelFork" targetRef="strategyEventGateway"/>
        
        <eventBasedGateway id="strategyEventGateway" name="等待触发策略"/>
        
        <sequenceFlow id="flow_gw_to_alarm" sourceRef="strategyEventGateway" targetRef="catchInternalAlarm"/>
        <sequenceFlow id="flow_gw_to_daily" sourceRef="strategyEventGateway" targetRef="catchDailyTimer"/>
        
        <!-- 事件 A: 捕获监控模块发出的报警信号 -->
        <intermediateCatchEvent id="catchInternalAlarm" name="捕获异常">
            <signalEventDefinition signalRef="internalAlarmSignal"/>
        </intermediateCatchEvent>
        
        <!-- 事件 B: 每天定时执行 (默认 0 点) -->
        <intermediateCatchEvent id="catchDailyTimer" name="每日巡检">
            <timerEventDefinition>
                <timeCycle>0 0 0 * * ?</timeCycle>
            </timerEventDefinition>
        </intermediateCatchEvent>
        
        <sequenceFlow id="flow_alarm_to_strat" sourceRef="catchInternalAlarm" targetRef="collectDataTask"/>
        <sequenceFlow id="flow_daily_to_strat" sourceRef="catchDailyTimer" targetRef="collectDataTask"/>
 
        <!-- 策略执行核心步骤 -->
        <serviceTask id="collectDataTask" name="收集数据" flowable:expression="${adStrategyService.collect(execution)}"/>
        <sequenceFlow id="flow_s1" sourceRef="collectDataTask" targetRef="produceStrategyTask"/>
        
        <serviceTask id="produceStrategyTask" name="产出策略" flowable:expression="${adStrategyService.decide(execution)}"/>
        
        <sequenceFlow id="flow_to_confirm_gw" sourceRef="produceStrategyTask" targetRef="confirmGateway"/>
        
        <exclusiveGateway id="confirmGateway" name="需要人工确认？" default="flow_skip_confirm"/>
        
        <!-- 路径：需要确认 -->
        <sequenceFlow id="flow_need_confirm" name="是" sourceRef="confirmGateway" targetRef="userConfirmTask">
            <conditionExpression xsi:type="tFormalExpression">${requiresConfirm == true}</conditionExpression>
        </sequenceFlow>
        
        <userTask id="userConfirmTask" name="人工确认" flowable:assignee="admin"/>
        
        <sequenceFlow id="flow_after_user_confirm" sourceRef="userConfirmTask" targetRef="executeActionTask"/>
        
        <!-- 路径：跳过确认 -->
        <sequenceFlow id="flow_skip_confirm" name="否" sourceRef="confirmGateway" targetRef="executeActionTask"/>
        
        <serviceTask id="executeActionTask" name="应用动作" flowable:expression="${adStrategyService.execute(execution)}"/>
        <sequenceFlow id="flow_s4" sourceRef="executeActionTask" targetRef="reviewAnalysisTask"/>
        
        <serviceTask id="reviewAnalysisTask" name="复盘分析" flowable:expression="${adStrategyService.review(execution)}"/>
        <sequenceFlow id="flow_strat_loop" sourceRef="reviewAnalysisTask" targetRef="strategyEventGateway"/>
 
    </process>
 
    <bpmndi:BPMNDiagram id="BPMNDiagram_adAgent">
        <bpmndi:BPMNPlane id="BPMNPlane_adAgent" bpmnElement="adAgentProcess">
            <!-- Start and Fork -->
            <bpmndi:BPMNShape id="BPMNShape_startEvent" bpmnElement="startEvent">
                <omgdc:Bounds x="100" y="200" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="BPMNShape_parallelFork" bpmnElement="parallelFork">
                <omgdc:Bounds x="200" y="193" width="50" height="50"/>
            </bpmndi:BPMNShape>
 
            <!-- Branch 1: Monitor -->
            <bpmndi:BPMNShape id="BPMNShape_monitorTask" bpmnElement="monitorTask">
                <omgdc:Bounds x="300" y="80" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="BPMNShape_monitorAlarmGateway" bpmnElement="monitorAlarmGateway" isMarkerVisible="true">
                <omgdc:Bounds x="450" y="95" width="50" height="50"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="BPMNShape_throwAlarmSignal" bpmnElement="throwAlarmSignal">
                <omgdc:Bounds x="550" y="102" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="BPMNShape_monitorWaitTimer" bpmnElement="monitorWaitTimer">
                <omgdc:Bounds x="650" y="102" width="36" height="36"/>
            </bpmndi:BPMNShape>
 
            <!-- Branch 2: Strategy -->
            <bpmndi:BPMNShape id="BPMNShape_strategyEventGateway" bpmnElement="strategyEventGateway">
                <omgdc:Bounds x="300" y="300" width="50" height="50"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="BPMNShape_catchInternalAlarm" bpmnElement="catchInternalAlarm">
                <omgdc:Bounds x="450" y="260" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="BPMNShape_catchDailyTimer" bpmnElement="catchDailyTimer">
                <omgdc:Bounds x="450" y="340" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="BPMNShape_collectDataTask" bpmnElement="collectDataTask">
                <omgdc:Bounds x="550" y="285" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="BPMNShape_produceStrategyTask" bpmnElement="produceStrategyTask">
                <omgdc:Bounds x="700" y="285" width="100" height="80"/>
            </bpmndi:BPMNShape>
            
            <!-- Gateway for Confirm -->
            <bpmndi:BPMNShape id="BPMNShape_confirmGateway" bpmnElement="confirmGateway" isMarkerVisible="true">
                <omgdc:Bounds x="825" y="300" width="50" height="50"/>
            </bpmndi:BPMNShape>
            
            <bpmndi:BPMNShape id="BPMNShape_userConfirmTask" bpmnElement="userConfirmTask">
                <omgdc:Bounds x="900" y="230" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="BPMNShape_executeActionTask" bpmnElement="executeActionTask">
                <omgdc:Bounds x="1050" y="285" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="BPMNShape_reviewAnalysisTask" bpmnElement="reviewAnalysisTask">
                <omgdc:Bounds x="1200" y="285" width="100" height="80"/>
            </bpmndi:BPMNShape>
 
            <!-- Edges -->
            <bpmndi:BPMNEdge id="BPMNEdge_flow_start_to_fork" bpmnElement="flow_start_to_fork">
                <omgdi:waypoint x="136" y="218"/>
                <omgdi:waypoint x="200" y="218"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_fork_to_monitor" bpmnElement="flow_fork_to_monitor">
                <omgdi:waypoint x="225" y="193"/>
                <omgdi:waypoint x="225" y="120"/>
                <omgdi:waypoint x="300" y="120"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_fork_to_strat_gw" bpmnElement="flow_fork_to_strat_gw">
                <omgdi:waypoint x="225" y="243"/>
                <omgdi:waypoint x="225" y="325"/>
                <omgdi:waypoint x="300" y="325"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_gw_to_alarm" bpmnElement="flow_gw_to_alarm">
                <omgdi:waypoint x="350" y="325"/>
                <omgdi:waypoint x="380" y="325"/>
                <omgdi:waypoint x="380" y="278"/>
                <omgdi:waypoint x="450" y="278"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_gw_to_daily" bpmnElement="flow_gw_to_daily">
                <omgdi:waypoint x="350" y="325"/>
                <omgdi:waypoint x="380" y="325"/>
                <omgdi:waypoint x="380" y="358"/>
                <omgdi:waypoint x="450" y="358"/>
            </bpmndi:BPMNEdge>
            
            <bpmndi:BPMNEdge id="BPMNEdge_flow_to_confirm_gw" bpmnElement="flow_to_confirm_gw">
                <omgdi:waypoint x="800" y="325"/>
                <omgdi:waypoint x="825" y="325"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_need_confirm" bpmnElement="flow_need_confirm">
                <omgdi:waypoint x="850" y="300"/>
                <omgdi:waypoint x="850" y="270"/>
                <omgdi:waypoint x="900" y="270"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_skip_confirm" bpmnElement="flow_skip_confirm">
                <omgdi:waypoint x="875" y="325"/>
                <omgdi:waypoint x="1050" y="325"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_after_user_confirm" bpmnElement="flow_after_user_confirm">
                <omgdi:waypoint x="1000" y="270"/>
                <omgdi:waypoint x="1025" y="270"/>
                <omgdi:waypoint x="1025" y="325"/>
                <omgdi:waypoint x="1050" y="325"/>
            </bpmndi:BPMNEdge>
 
            <bpmndi:BPMNEdge id="BPMNEdge_flow_loop_monitor" bpmnElement="flow_loop_monitor">
                <omgdi:waypoint x="686" y="120"/>
                <omgdi:waypoint x="720" y="120"/>
                <omgdi:waypoint x="720" y="50"/>
                <omgdi:waypoint x="350" y="50"/>
                <omgdi:waypoint x="350" y="80"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="BPMNEdge_flow_strat_loop" bpmnElement="flow_strat_loop">
                <omgdi:waypoint x="1250" y="365"/>
                <omgdi:waypoint x="1250" y="450"/>
                <omgdi:waypoint x="325" y="450"/>
                <omgdi:waypoint x="325" y="350"/>
            </bpmndi:BPMNEdge>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>
</definitions>