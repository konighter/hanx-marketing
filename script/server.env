# --- 基础配置 ---
SPRING_PROFILES_ACTIVE=prod
TZ=Asia/Shanghai

# --- 数据库配置 (示例) ---
# SPRING_DATASOURCE_DYNAMIC_DATASOURCE_MASTER_URL=jdbc:mysql://127.0.0.1:3306/hzapp?useSSL=false
# SPRING_DATASOURCE_DYNAMIC_DATASOURCE_MASTER_USERNAME=root
# SPRING_DATASOURCE_DYNAMIC_DATASOURCE_MASTER_PASSWORD=你的密码

# --- Redis 配置 (示例) ---
# SPRING_DATA_REDIS_HOST=127.0.0.1
# SPRING_DATA_REDIS_PORT=6379
# SPRING_DATA_REDIS_PASSWORD=

# --- JVM 配置 ---
JAVA_OPTS=-Xms512m -Xmx512m -Djava.security.egd=file:/dev/./urandom
