<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://flowable.org/mas"
             exporter="Flowable"
             exporterVersion="7.0">

    <!--
        通用 Phase 循环子流程 (skill-task-loop)
        执行 "收集 → 决策 → 确认? → 执行 → 等待 → 复盘 → 循环判断" 的标准流程

        输入变量 (通过 CallActivity in 映射):
          - phaseName:        当前 Phase 名称
          - phaseInstruction: AI 决策指导书
          - maxIterations:    最大循环次数
          - taskInterval:     循环等待间隔 (ISO-8601, e.g. PT1H)
          - phaseTools:       本 Phase 可用工具集 (JSON)
          - sessionId:        AI 会话 ID
          - skillCode:        Skill 编码
          - targetBizId:      业务对象 ID
    -->

    <process id="skill-task-loop" name="Skill Task Loop" isExecutable="true">

        <!-- ===== Start ===== -->
        <startEvent id="startEvent" name="开始">
            <extensionElements>
                <flowable:executionListener event="start"
                    expression="${execution.setVariable('iteration', 0)}"/>
                <flowable:executionListener event="start"
                    expression="${execution.setVariable('requiresConfirm', true)}"/>
            </extensionElements>
        </startEvent>

        <!-- ===== 1. 收集数据 ===== -->
        <serviceTask id="collectTask" name="收集数据"
                     flowable:expression="${skillTaskDelegate.collect(execution)}"/>

        <!-- ===== 2. AI 决策 ===== -->
        <serviceTask id="decideTask" name="AI 决策"
                     flowable:expression="${skillTaskDelegate.decide(execution)}"/>

        <!-- ===== 3. 人工确认网关 ===== -->
        <exclusiveGateway id="confirmGateway" name="需要确认?"/>

        <!-- ===== 3a. 人工确认 UserTask ===== -->
        <userTask id="userConfirmTask" name="人工确认策略"
                  flowable:candidateGroups="mas-reviewer">
            <documentation>审核 AI 产出的策略决策，确认或驳回。</documentation>
        </userTask>

        <!-- ===== 4. 执行策略 ===== -->
        <serviceTask id="executeTask" name="执行策略"
                     flowable:expression="${skillTaskDelegate.execute(execution)}"/>

        <!-- ===== 5. 等待期 ===== -->
        <intermediateCatchEvent id="waitTimer" name="等待间隔">
            <timerEventDefinition>
                <timeDuration>${taskInterval}</timeDuration>
            </timerEventDefinition>
        </intermediateCatchEvent>

        <!-- ===== 6. 复盘分析 ===== -->
        <serviceTask id="reviewTask" name="复盘分析"
                     flowable:expression="${skillTaskDelegate.review(execution)}"/>

        <!-- ===== 7. 迭代计数器 +1 ===== -->
        <serviceTask id="iterationIncTask" name="迭代计数"
                     flowable:expression="${execution.setVariable('iteration', execution.getVariable('iteration') + 1)}"/>

        <!-- ===== 8. 循环判断网关 ===== -->
        <exclusiveGateway id="loopGateway" name="继续循环?"/>

        <!-- ===== End ===== -->
        <endEvent id="endEvent" name="Phase 完成"/>

        <!-- ========== Sequence Flows ========== -->

        <sequenceFlow id="flow_start_collect" sourceRef="startEvent" targetRef="collectTask"/>
        <sequenceFlow id="flow_collect_decide" sourceRef="collectTask" targetRef="decideTask"/>
        <sequenceFlow id="flow_decide_confirm" sourceRef="decideTask" targetRef="confirmGateway"/>

        <!-- 需要确认 → UserTask -->
        <sequenceFlow id="flow_confirm_yes" sourceRef="confirmGateway" targetRef="userConfirmTask">
            <conditionExpression xsi:type="tFormalExpression">${requiresConfirm == true}</conditionExpression>
        </sequenceFlow>

        <!-- 不需要确认 → 直接执行 -->
        <sequenceFlow id="flow_confirm_no" sourceRef="confirmGateway" targetRef="executeTask">
            <conditionExpression xsi:type="tFormalExpression">${requiresConfirm == false}</conditionExpression>
        </sequenceFlow>

        <!-- 确认完成 → 执行 -->
        <sequenceFlow id="flow_userConfirm_execute" sourceRef="userConfirmTask" targetRef="executeTask"/>

        <sequenceFlow id="flow_execute_wait" sourceRef="executeTask" targetRef="waitTimer"/>
        <sequenceFlow id="flow_wait_review" sourceRef="waitTimer" targetRef="reviewTask"/>
        <sequenceFlow id="flow_review_inc" sourceRef="reviewTask" targetRef="iterationIncTask"/>
        <sequenceFlow id="flow_inc_loop" sourceRef="iterationIncTask" targetRef="loopGateway"/>

        <!-- 继续循环 -->
        <sequenceFlow id="flow_loop_continue" sourceRef="loopGateway" targetRef="collectTask">
            <conditionExpression xsi:type="tFormalExpression">${iteration &lt; maxIterations}</conditionExpression>
        </sequenceFlow>

        <!-- 循环结束 -->
        <sequenceFlow id="flow_loop_end" sourceRef="loopGateway" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">${iteration >= maxIterations}</conditionExpression>
        </sequenceFlow>

    </process>

    <!-- ========== BPMN Diagram ========== -->
    <bpmndi:BPMNDiagram id="BPMNDiagram_skill_task_loop">
        <bpmndi:BPMNPlane bpmnElement="skill-task-loop" id="BPMNPlane_skill_task_loop">
            <bpmndi:BPMNShape id="shape_startEvent" bpmnElement="startEvent">
                <omgdc:Bounds x="100" y="200" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="shape_collectTask" bpmnElement="collectTask">
                <omgdc:Bounds x="190" y="178" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="shape_decideTask" bpmnElement="decideTask">
                <omgdc:Bounds x="340" y="178" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="shape_confirmGateway" bpmnElement="confirmGateway">
                <omgdc:Bounds x="490" y="193" width="50" height="50"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="shape_userConfirmTask" bpmnElement="userConfirmTask">
                <omgdc:Bounds x="465" y="60" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="shape_executeTask" bpmnElement="executeTask">
                <omgdc:Bounds x="620" y="178" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="shape_waitTimer" bpmnElement="waitTimer">
                <omgdc:Bounds x="770" y="200" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="shape_reviewTask" bpmnElement="reviewTask">
                <omgdc:Bounds x="860" y="178" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="shape_iterationIncTask" bpmnElement="iterationIncTask">
                <omgdc:Bounds x="1010" y="178" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="shape_loopGateway" bpmnElement="loopGateway">
                <omgdc:Bounds x="1160" y="193" width="50" height="50"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="shape_endEvent" bpmnElement="endEvent">
                <omgdc:Bounds x="1280" y="200" width="36" height="36"/>
            </bpmndi:BPMNShape>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>

</definitions>
